{
  "lnf.aliases": {
    "$/": "${workspaceRoot}/",
    "$components/": "${workspaceRoot}/src/components/",
    "@*/": "${workspaceRoot}/apps/$1/",
    "$*/": "${workspaceRoot}/packages/$1/"
  },
  "editor.defaultFormatter": "biomejs.biome",
  "biome.enabled": true,
  "deno.enable": true,
  "deno.enablePaths": [
    "./apps/api/"
  ]
}